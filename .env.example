# ============================================================================
# EMS Application - Docker Environment Configuration Template
# ============================================================================
# Copy this to .env and update values for your environment
# DO NOT commit .env file with sensitive data to version control
#
# For production, use Docker Secrets, Kubernetes Secrets, or environment 
# variable injection instead of .env files
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
# PostgreSQL connection and credentials

# Database hostname (use 'postgres' in docker-compose network)
DB_HOST=postgres

# Database port
DB_PORT=5432

# Database name
DB_NAME=employee_dev

# Database user
DB_USERNAME=postgres

# Database password
# IMPORTANT: Change this in production to a secure password
# Requirements: min 12 chars, mix of uppercase, lowercase, numbers, special chars
DB_[REDACTED_GENERIC_PASSWORD_5]=postgres_dev_password_123

# ============================================================================
# SPRING BOOT BACKEND CONFIGURATION
# ============================================================================

# Spring Boot active profile (dev, qa, prod)
# - dev: Development with verbose logging
# - qa: QA/Staging environment
# - prod: Production environment with optimized settings
SPRING_PROFILES_ACTIVE=dev

# Backend server port
BACKEND_PORT=8080

# Java JVM options (container-specific optimizations)
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=50.0

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend port (Nginx HTTP)
FRONTEND_PORT=80

# API URL for React frontend (used during build time for API proxy)
REACT_APP_API_URL=http://localhost:8080/api

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Logging level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=DEBUG

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. COPY THIS FILE:
#    cp .env.example .env
#
# 2. UPDATE SECRETS:
#    - Change DB_[REDACTED_GENERIC_PASSWORD_5] to a secure password
#    - For production, use complex passwords with special characters
#
# 3. RUN APPLICATION:
#    docker-compose up -d
#
# 4. VERIFY SERVICES:
#    docker-compose ps
#    docker-compose logs -f
#
# 5. ACCESS APPLICATION:
#    - Frontend: http://localhost
#    - Backend: http://localhost:8080
#    - API Docs: http://localhost:8080/actuator
#
# ============================================================================
# PRODUCTION CONSIDERATIONS
# ============================================================================
#
# 1. SECURITY:
#    - Never commit .env with real passwords to git
#    - Use git hooks or .gitignore to prevent accidental commits
#    - Use Docker Secrets for Swarm mode
#    - Use environment injection for Kubernetes
#
# 2. DATABASE:
#    - Change default credentials
#    - Enable SSL/TLS for database connections
#    - Implement connection pooling
#    - Set up regular backups: docker-compose exec postgres pg_dump -U postgres employee_dev > backup.sql
#
# 3. BACKEND:
#    - Set SPRING_PROFILES_ACTIVE=prod
#    - Increase heap memory if needed
#    - Enable monitoring and metrics
#    - Review spring-boot actuator endpoints (disabled in prod)
#
# 4. FRONTEND:
#    - Set API_URL to production backend address
#    - Enable caching headers in Nginx
#    - Use HTTPS/TLS termination
#    - Configure CDN for static assets
#
# ============================================================================
